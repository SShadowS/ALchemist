{
  "name": "al-chemist",
  "displayName": "ALchemist - AL Live Runner",
  "description": "Quokka-style live execution and inline feedback for AL (Business Central)",
  "version": "0.5.8",
  "publisher": "SShadowSdk",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SShadowS/ALchemist"
  },
  "homepage": "https://github.com/SShadowS/ALchemist#readme",
  "bugs": {
    "url": "https://github.com/SShadowS/ALchemist/issues"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "keywords": [
    "AL",
    "Business Central",
    "Dynamics 365",
    "test runner",
    "live coding"
  ],
  "activationEvents": [
    "onLanguage:al",
    "onCommand:alchemist.newScratchFile",
    "onCommand:alchemist.runNow"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "colors": [
      {
        "id": "alchemist.capturedValueForeground",
        "description": "Color for captured variable values shown inline after assignments.",
        "defaults": {
          "dark": "#9cdcfe",
          "light": "#0451a5",
          "highContrast": "#9cdcfe",
          "highContrastLight": "#0451a5"
        }
      },
      {
        "id": "alchemist.messageForeground",
        "description": "Color for Message() output shown inline.",
        "defaults": {
          "dark": "#6a9955",
          "light": "#008000",
          "highContrast": "#6a9955",
          "highContrastLight": "#008000"
        }
      },
      {
        "id": "alchemist.errorForeground",
        "description": "Color for error messages shown inline.",
        "defaults": {
          "dark": "#f14c4c",
          "light": "#cd3131",
          "highContrast": "#f14c4c",
          "highContrastLight": "#cd3131"
        }
      },
      {
        "id": "alchemist.changedValueBackground",
        "description": "Background highlight for values that changed between iterations.",
        "defaults": {
          "dark": "rgba(86, 156, 214, 0.15)",
          "light": "rgba(0, 122, 204, 0.1)",
          "highContrast": "rgba(86, 156, 214, 0.25)",
          "highContrastLight": "rgba(0, 122, 204, 0.15)"
        }
      }
    ],
    "commands": [
      {
        "command": "alchemist.newScratchFile",
        "title": "ALchemist: New Scratch File"
      },
      {
        "command": "alchemist.toggleProjectContext",
        "title": "ALchemist: Toggle Project Context"
      },
      {
        "command": "alchemist.deleteScratchFile",
        "title": "ALchemist: Delete Scratch File"
      },
      {
        "command": "alchemist.saveScratchAs",
        "title": "ALchemist: Save Scratch As..."
      },
      {
        "command": "alchemist.runNow",
        "title": "ALchemist: Run Now"
      },
      {
        "command": "alchemist.stopRun",
        "title": "ALchemist: Stop Run"
      },
      {
        "command": "alchemist.clearDecorations",
        "title": "ALchemist: Clear Results"
      },
      {
        "command": "alchemist.showOutput",
        "title": "ALchemist: Show Output"
      },
      {
        "command": "alchemist.iterationNext",
        "title": "ALchemist: Next Iteration"
      },
      {
        "command": "alchemist.iterationPrev",
        "title": "ALchemist: Previous Iteration"
      },
      {
        "command": "alchemist.iterationFirst",
        "title": "ALchemist: First Iteration"
      },
      {
        "command": "alchemist.iterationLast",
        "title": "ALchemist: Last Iteration"
      },
      {
        "command": "alchemist.iterationShowAll",
        "title": "ALchemist: Show All Iterations"
      },
      {
        "command": "alchemist.iterationTable",
        "title": "ALchemist: Open Iteration Table"
      },
      {
        "command": "alchemist.runWiderScope",
        "title": "ALchemist: Run Wider Scope (Force Fallback)"
      }
    ],
    "keybindings": [
      {
        "command": "alchemist.newScratchFile",
        "key": "ctrl+shift+a n"
      },
      {
        "command": "alchemist.runNow",
        "key": "ctrl+shift+a r"
      },
      {
        "command": "alchemist.clearDecorations",
        "key": "ctrl+shift+a c"
      },
      {
        "command": "alchemist.iterationNext",
        "key": "ctrl+shift+a right",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.iterationPrev",
        "key": "ctrl+shift+a left",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.iterationFirst",
        "key": "ctrl+shift+a home",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.iterationLast",
        "key": "ctrl+shift+a end",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.iterationShowAll",
        "key": "ctrl+shift+a a",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.iterationTable",
        "key": "ctrl+shift+a t",
        "when": "alchemist.hasIterationData"
      },
      {
        "command": "alchemist.runWiderScope",
        "key": "ctrl+shift+a shift+r",
        "when": "editorTextFocus && editorLangId == al"
      }
    ],
    "configuration": {
      "title": "ALchemist",
      "properties": {
        "alchemist.alRunnerPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to al-runner binary. Leave empty for auto-managed."
        },
        "alchemist.dotnetPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to dotnet SDK."
        },
        "alchemist.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Execute automatically on file save."
        },
        "alchemist.testRunOnSave": {
          "type": "string",
          "enum": [
            "current",
            "all",
            "off"
          ],
          "default": "current",
          "description": "Which tests to run on save. 'current' = tests in the saved file's app plus apps transitively depending on it. 'all' = every test in every AL app in the workspace. 'off' = no save-triggered runs."
        },
        "alchemist.showOutputOnError": {
          "type": "string",
          "enum": [
            "always",
            "never",
            "onlyOnFailure"
          ],
          "default": "onlyOnFailure",
          "description": "When to auto-focus the output panel."
        },
        "alchemist.showInlineMessages": {
          "type": "boolean",
          "default": true,
          "description": "Show Message()/Error() output inline in the editor."
        },
        "alchemist.showGutterCoverage": {
          "type": "boolean",
          "default": true,
          "description": "Show coverage gutter indicators."
        },
        "alchemist.showHitCounts": {
          "type": "boolean",
          "default": true,
          "description": "Show hit counts on repeated lines (requires AL.Runner API — Phase 2)."
        },
        "alchemist.dimUncoveredLines": {
          "type": "boolean",
          "default": true,
          "description": "Reduce opacity of lines not reached."
        },
        "alchemist.showCapturedValues": {
          "type": "boolean",
          "default": true,
          "description": "Show captured variable values inline."
        },
        "alchemist.showIterationStepper": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens iteration stepper above loops. Requires window reload to take effect."
        },
        "alchemist.iterationFlashDuration": {
          "type": "number",
          "default": 600,
          "description": "Duration in ms for the value change flash when stepping (0 to disable)."
        },
        "alchemist.iterationHoverDetail": {
          "type": "string",
          "enum": [
            "minimal",
            "values",
            "rich"
          ],
          "default": "rich",
          "description": "Detail level for iteration hover: minimal (nav only), values (nav + variables), rich (nav + variables + messages)."
        },
        "alchemist.scratchProjectAppId": {
          "type": "string",
          "default": "",
          "description": "GUID (app.json 'id') of the AL app to use as context for project-aware scratch files. Leave empty to be prompted."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./tsconfig.json",
    "test:unit": "npm run test-compile && npx mocha out/test/suite/*.test.js",
    "test:integration": "npm run test-compile && node ./out/test/runIntegrationTests.js",
    "test:smoke": "npm run package && npm run test-compile && node ./out/test/runSmokeTests.js",
    "test:parity": "npm run package && npm run test-compile && node ./out/test/runParityTests.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:parity",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sshadows/tree-sitter-al": "^2.5.0",
    "fast-xml-parser": "^5.5.11",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.88.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "sinon": "^21.1.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
